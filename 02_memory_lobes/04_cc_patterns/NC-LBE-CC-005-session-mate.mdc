## 6. API DO SESSIONMATE (NCSVCFR009SESSIONBUDDY.PY)

### Mtodos principais

```python
class SessionMate:
    def __init__(self, metrics_collector: MetricsCollector):
        """Inicializa com referncia ao MetricsCollector."""
        self.metrics = metrics_collector
        self.task_count = 0
        self.success_count = 0
        self.total_tokens = 0
        self.session_start = time.time()

    def start_session(self) -> None:
        """Inicia nova sesso (reset contadores)."""
        self.task_count = 0
        self.success_count = 0
        self.total_tokens = 0
        self.session_start = time.time()

    def record_task(self, success: bool, tokens: int) -> None:
        """Registra concluso de uma task."""
        self.task_count += 1
        if success:
            self.success_count += 1
        self.total_tokens += tokens

    def end_session(self) -> str:
        """Finaliza sesso e retorna resumo formatado."""
        session_duration = time.time() - self.session_start
        summary = self.metrics.get_session_summary()

        # Clculos
        success_rate = (
            (self.success_count / self.task_count * 100) if self.task_count > 0 else 0.0
        )
        avg_time = (
            session_duration / self.task_count if self.task_count > 0 else 0.0
        )

        # Formatao
        cost_str = f"${summary['total_cost_usd']:.2f}"
        success_str = f"{success_rate:.0f}%"
        avg_time_str = self._format_duration(avg_time)

        return f" {self.task_count} tasks |  {cost_str} |  {success_str} success |  {avg_time_str} avg"

    def _format_duration(self, seconds: float) -> str:
        """Formata durao em minutos:segundos."""
        if seconds < 60:
            return f"{seconds:.1f}s"
        minutes = int(seconds // 60)
        secs = int(seconds % 60)
        return f"{minutes}m{secs:02d}s"
```

### Integrao com hooks existentes

- **Mentor Mode:** pode chamar `record_task` aps cada handoff (`status=DONE`).
- **PulseScheduler:** pode chamar `end_session` aps inatividade > 5min.
- **Health endpoint:** incluir resumo da sesso em `/health` (opcional).

