def open_pixel_agents(self):
    """Abre VS Code com workspace atual para visualizao no Pixel Agents"""
    import subprocess
    import os
    
    workspace_path = os.getcwd()  # ou obter do NeoCortex config
    cmd = ["code", workspace_path]
    
    try:
        subprocess.Popen(cmd, shell=False)
        self.log("Pixel Agents: VS Code launched with workspace")
