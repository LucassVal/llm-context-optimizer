##  NCCFGFR004PROJECTLOADER.PY (ESBOO)

**Localizao:** `01_neocortex_framework/neocortex/core/config/NCCFGFR004projectloader.py`  
**Responsabilidade:** Buscar `.nc/` na hierarquia de diretrios, fazer merge seguro, expor configurao final.

**API principal:**
```python
class ProjectConfigLoader:
    def __init__(self, global_config: dict):
        self.global_config = global_config
        self.local_config = self._find_and_load_local_config()

    def _find_and_load_local_config(self) -> dict:
        """Sobe a rvore de diretrios buscando .nc/config.yaml."""
        cwd = Path.cwd()
        while cwd != cwd.parent:
            nc_dir = cwd / ".nc"
            if nc_dir.is_dir():
                config_file = nc_dir / "config.yaml"
                if config_file.is_file():
                    return self._load_yaml(config_file)
            cwd = cwd.parent
        return {}

    def get_merged_config(self) -> dict:
        """Retorna configurao final (global + local merge)."""
        return merge_configs(self.global_config, self.local_config)

    def get_hooks_dir(self) -> Optional[Path]:
        """Retorna caminho para .nc/hooks/ se existir."""
        # ... implementao

    def get_plugins_dir(self) -> Optional[Path]:
        """Retorna caminho para .nc/plugins/ se existir."""
        # ... implementao
```

**Integrao com `get_config()` existente:**
```python
# Em neocortex/core/config/__init__.py
from .NC_CFG_FR_004_project_loader import ProjectConfigLoader

def get_config() -> dict:
    global _cached_config
    if _cached_config is None:
        global_raw = _load_global_config()
        loader = ProjectConfigLoader(global_raw)
        _cached_config = loader.get_merged_config()
    return _cached_config
```

