{
  "mcpServers": {
    "neocortex-stdio": {
      "name": "NeoCortex Framework (stdio)",
      "command": "python",
      "args": [
        "-m",
        "neocortex.mcp.server",
        "--transport",
        "stdio"
      ],
      "env": {},
      "disabled": false,
      "autoApprove": [
        "neocortex_cortex",
        "neocortex_ledger",
        "neocortex_report",
        "neocortex_checkpoint",
        "neocortex_config",
        "neocortex_lobes",
        "neocortex_search",
        "neocortex_agent",
        "neocortex_pulse",
        "neocortex_governance"
      ]
    },
    "neocortex-websocket": {
      "name": "NeoCortex Framework (WebSocket)",
      "url": "ws://localhost:8770",
      "disabled": false,
      "autoApprove": [
        "neocortex_cortex",
        "neocortex_ledger",
        "neocortex_report",
        "neocortex_checkpoint",
        "neocortex_config",
        "neocortex_lobes",
        "neocortex_search",
        "neocortex_agent",
        "neocortex_pulse",
        "neocortex_governance"
      ]
    }
  }
}