### 3. hooks/NCHK001example.py (Hook Exemplo)
```python
"""
NCHK001example.py  Example hook for NCTOOLFRXXX.
"""

import sys
import json

def main():
    # Hook receives context via stdin (JSON)
    context = json.loads(sys.stdin.read())
    tool_name = context.get("tool_name")
    # Decision: allow, warn, or block
    print(json.dumps({
        "action": "allow",
        "message": f"Tool {tool_name} allowed by hook."
    }))

if __name__ == "__main__":
    main()
```

