def on_handoff_submitted(event):
    if is_enabled('push_notifications'):
        PushNotificationTool().send_notification(
            title="Handoff Gerado",
            message=f"Ticket {event.payload['ticket_id']} concludo"
        )

event_bus.subscribe(HANDOFF_SUBMITTED, on_handoff_submitted)
```

