  "lsp": {
    "pyright": { "env": { "PYTHONPATH": "01_neocortex_framework" } },
    "yaml_ls": {},
    "rust": {},
    "typescript": {},
    "eslint": {},
    "oxlint": {}
  }
}
```





@UBL lsp-disable
